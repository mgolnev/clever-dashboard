# Конфигурация CLEVER Dashboard. Скопируйте в .env и заполните под окружение.
# cp .env.example .env

# Порт HTTP-сервера (внутри контейнера)
PORT=8080

# Порт, на котором приложение доступно на хосте (маппинг docker-compose)
APP_PORT=8080

# База данных: sqlite (по умолчанию) или postgres
DB_DRIVER=sqlite

# DSN. Для sqlite — путь к файлу (в Docker монтируется в volume clever-data).
# Для postgres — строка подключения.
DB_DSN=/app/data/clever.db
# Пример для Postgres (раскомментируйте db в compose профилем postgres):
# DB_DRIVER=postgres
# DB_DSN=postgres://clever:clever@db:5432/clever?sslmode=disable

# Каталог собранного фронтенда внутри контейнера (single-binary режим).
STATIC_DIR=/app/web

# Пилот логистики (опционально)
LOGISTICS_PILOT_CITIES=
LOGISTICS_PILOT_START=

# --- Параметры опционального Postgres-контейнера ---
POSTGRES_USER=clever
POSTGRES_PASSWORD=clever
POSTGRES_DB=clever
POSTGRES_PORT=5432
